# Backend API — e.g. https://mycredaxis.com/api (via nginx reverse proxy)

PORT=5000
NODE_ENV=production

JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

MONGO_USER=
MONGO_PASSWORD=
MONGO_HOST=
MONGO_DB=
MONGO_OPTIONS=

# Optional: restrict browser origins (app currently allows all with origin:true)
# CORS_ORIGIN=https://mycredaxis.com

# Decentro
DECENTRO_BASE_URL=https://in.decentro.tech
DECENTRO_CLIENT_ID=
DECENTRO_CLIENT_SECRET=
DECENTRO_CREDIT_REPORT_PATH=/v2/financial_services/credit_bureau/credit_report/summary
DECENTRO_TIMEOUT_MS=60000
